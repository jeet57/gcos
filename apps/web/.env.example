# GCOS Web — Environment Variables
# Copy this file to .env.local and fill in real values for local development.
# .env.local is gitignored — never commit real secrets.

# --- API connection -----------------------------------------------------------
# The NestJS API base URL. Matches apps/api PORT in docker-compose-driven local dev.
# No API routes consume this yet (introduced from M10 onward) — documented now
# so the full variable surface is known from M02.
NEXT_PUBLIC_API_URL="http://localhost:3001"
