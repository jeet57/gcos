# GCOS API — Environment Variables
# Copy this file to .env.local and fill in real values for local development.
# .env.local is gitignored — never commit real secrets.

# --- Database ---------------------------------------------------------------
# Local dev (docker-compose): postgres / password / gcos_dev as set in
# docker-compose.yml. Do not change the credentials here without also
# updating docker-compose.yml.
DATABASE_URL="postgresql://postgres:password@localhost:5432/gcos_dev"

# --- Auth (introduced in M08 — placeholders documented now so the full
# variable surface is known from M02 onward) ---------------------------------
# Generate with: openssl rand -base64 48
JWT_SECRET="replace-with-a-64-character-random-string-before-first-use"
JWT_REFRESH_SECRET="replace-with-a-different-64-character-random-string"

# --- Server -------------------------------------------------------------------
PORT=3001

# --- CORS (introduced in M07) ------------------------------------------------
# The production apps/web domain, allowed alongside http://localhost:3000.
# Leave unset in local dev.
PRODUCTION_WEB_ORIGIN=
